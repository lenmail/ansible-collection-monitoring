groups:
- name: prometheus
  rules:
  - alert: Prometheus Configuration Reload
    expr: prometheus_config_last_reload_successful != 1
    for: 1m
    labels:
      severity: critical
    annotations:
      metric_name: prometheus_config_last_reload_successful%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Prometheus configuration reload on {{ $labels.hostname }}'
      description: 'Prometheus configuration reload error'
  - alert: Prometheus Too Many Restarts
    expr: changes(process_start_time_seconds{alerting_required!='false',job=~'prometheus|pushgateway|alertmanager|windows-exporter'}[15m]) > 2
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: changes(process_start_time_seconds%7Binstance='{{  $labels.instance  }}',job=%7E'prometheus%7Cpushgateway%7Calertmanager%7Cwindows-exporter'%7D%5b15m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus too many restarts (instance {{ $labels.hostname }})'
      description: 'Prometheus has restarted more than twice in the last 15 minutes. It might be crashlooping.'
  - alert: Prometheus Not Connected To Alertmanager
    expr: prometheus_notifications_alertmanagers_discovered{hostname!~".*wolf.local"} < 1
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: prometheus_notifications_alertmanagers_discovered%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Prometheus not connected to alertmanager (instance {{ $labels.hostname }})'
      description: 'Prometheus cannot connect the alertmanager'
  - alert: Prometheus Alertmanager Notification Failing
    expr: rate(alertmanager_notifications_failed_total[1m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: rate(alertmanager_notifications_failed_total%7Binstance='{{  $labels.instance  }}'%7D%5b1m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus AlertManager notification failing (instance {{ $labels.hostname }})'
      description: 'Alertmanager is failing sending notifications'
  - alert: Prometheus Rule Evaluation Failures
    expr: increase(prometheus_rule_evaluation_failures_total[3m]) > 0
    for: 3m
    labels:
      severity: warning
    annotations:
      metric_name: increase(prometheus_rule_evaluation_failures_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus rule evaluation failures (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} rule evaluation failures, leading to potentially ignored alerts.'
  - alert: Prometheus Template Text Expansion Failures
    expr: increase(prometheus_template_text_expansion_failures_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_template_text_expansion_failures_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus template text expansion failures (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} template text expansion failures'
  - alert: Prometheus Rule Evaluation Slow
    expr: prometheus_rule_group_last_duration_seconds > prometheus_rule_group_interval_seconds
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: prometheus_rule_group_last_duration_seconds%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Prometheus rule evaluation slow (instance {{ $labels.hostname }})'
      description: 'Prometheus rule evaluation took more time than the scheduled interval. I indicates a slower storage backend access or too complex query.'
  - alert: Prometheus Notifications Backlog
    expr: min_over_time(prometheus_notifications_queue_length[10m]) > 0
    for: 10m
    labels:
      severity: standard
    annotations:
      metric_name: min_over_time(prometheus_notifications_queue_length%7Binstance='{{  $labels.instance  }}'%7D%5b10m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus notifications backlog (instance {{ $labels.hostname }})'
      description: 'The Prometheus notification queue has not been empty for 10 minutes'
  - alert: Prometheus Large Scrape
    expr: increase(prometheus_target_scrapes_exceeded_sample_limit_total[10m]) > 10
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: increase(prometheus_target_scrapes_exceeded_sample_limit_total%7Binstance='{{  $labels.instance  }}'%7D%5b10m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus large scrape (instance {{ $labels.hostname }})'
      description: 'Prometheus has many scrapes that exceed the sample limit'
  - alert: Prometheus Target Scrape Duplicate
    expr: increase(prometheus_target_scrapes_sample_duplicate_timestamp_total[5m]) > 0
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: increase(prometheus_target_scrapes_sample_duplicate_timestamp_total%7Binstance='{{  $labels.instance  }}'%7D%5b5m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus target scrape duplicate (instance {{ $labels.hostname }})'
      description: 'Prometheus has many samples rejected due to duplicate timestamps but different values'
  - alert: Prometheus Tsdb Checkpoint Creation Failures
    expr: increase(prometheus_tsdb_checkpoint_creations_failed_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_checkpoint_creations_failed_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB checkpoint creation failures (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} checkpoint creation failures'
  - alert: Prometheus Tsdb Checkpoint Deletion Failures
    expr: increase(prometheus_tsdb_checkpoint_deletions_failed_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_checkpoint_deletions_failed_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB checkpoint deletion failures (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} checkpoint deletion failures'
  - alert: Prometheus Tsdb Compactions Failed
    expr: increase(prometheus_tsdb_compactions_failed_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_compactions_failed_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB compactions failed (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} TSDB compactions failures'
  - alert: Prometheus TsdbHead Truncations Failed
    expr: increase(prometheus_tsdb_head_truncations_failed_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_head_truncations_failed_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB head truncations failed (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} TSDB head truncation failures'
  - alert: Prometheus Tsdb Reload Failures
    expr: increase(prometheus_tsdb_reloads_failures_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_reloads_failures_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB reload failures (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} TSDB reload failures'
  - alert: Prometheus Tsdb Wal Corruptions
    expr: increase(prometheus_tsdb_wal_corruptions_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_wal_corruptions_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB WAL corruptions (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} TSDB WAL corruptions'
  - alert: Prometheus Tsdb Wal Truncations Failed
    expr: increase(prometheus_tsdb_wal_truncations_failed_total[3m]) > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: increase(prometheus_tsdb_wal_truncations_failed_total%7Binstance='{{  $labels.instance  }}'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Prometheus TSDB WAL truncations failed (instance {{ $labels.hostname }})'
      description: 'Prometheus encountered {{ $value }} TSDB WAL truncation failures'
