groups:
- name: elasticsearch_exporter
  rules:
  - alert: ElasticsearchHeapUsageTooHigh
    expr: (elasticsearch_jvm_memory_used_bytes{alerting_required!='false',area='heap'} / elasticsearch_jvm_memory_max_bytes{area='heap'}) * 100 > 90
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: (elasticsearch_jvm_memory_used_bytes%7Binstance='{{  $labels.instance  }}',area='heap'%7D / elasticsearch_jvm_memory_max_bytes%7Barea='heap'%7D) * 100 
      value: '{{ $value }}'
      summary: 'Elasticsearch Heap Usage Too High (instance {{ $labels.instance }})'
      description: 'The heap usage is over 90% for 5m'
  - alert: ElasticsearchHeapUsageWarning
    expr: (elasticsearch_jvm_memory_used_bytes{alerting_required!='false',area='heap'} / elasticsearch_jvm_memory_max_bytes{area='heap'}) * 100 > 80
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: (elasticsearch_jvm_memory_used_bytes%7Binstance='{{  $labels.instance  }}',area='heap'%7D / elasticsearch_jvm_memory_max_bytes%7Barea='heap'%7D) * 100 
      value: '{{ $value }}'
      summary: 'Elasticsearch Heap Usage warning (instance {{ $labels.instance }})'
      description: 'The heap usage is over 80% for 5m'
  - alert: ElasticsearchDiskSpaceLow
    expr: elasticsearch_filesystem_data_available_bytes{alerting_required!='false'}  / elasticsearch_filesystem_data_size_bytes * 100 < 20
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: elasticsearch_filesystem_data_available_bytes%7Binstance='{{  $labels.instance  }}'%7D  / elasticsearch_filesystem_data_size_bytes * 100 
      value: '{{ $value }}'
      summary: 'Elasticsearch disk space low (instance {{ $labels.instance }})'
      description: 'The disk usage is over 80%'
  - alert: ElasticsearchDiskOutOfSpace
    expr: elasticsearch_filesystem_data_available_bytes{alerting_required!='false'} / elasticsearch_filesystem_data_size_bytes * 100 < 10
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: elasticsearch_filesystem_data_available_bytes%7Binstance='{{  $labels.instance  }}'%7D / elasticsearch_filesystem_data_size_bytes * 100 
      value: '{{ $value }}'
      summary: 'Elasticsearch disk out of space (instance {{ $labels.instance }})'
      description: 'The disk usage is over 90%'
  - alert: ElasticsearchClusterRed
    expr: elasticsearch_cluster_health_status{alerting_required!='false',color='red'} == 1
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: elasticsearch_cluster_health_status%7Binstance='{{  $labels.instance  }}',color='red'%7D 
      value: '{{ $value }}'
      summary: 'Elasticsearch Cluster Red (instance {{ $labels.instance }})'
      description: 'Elastic Cluster Red status'
  - alert: ElasticsearchClusterYellow
    expr: elasticsearch_cluster_health_status{alerting_required!='false',color='yellow'} == 1
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: elasticsearch_cluster_health_status%7Binstance='{{  $labels.instance  }}',color='yellow'%7D 
      value: '{{ $value }}'
      summary: 'Elasticsearch Cluster Yellow (instance {{ $labels.instance }})'
      description: 'Elastic Cluster Yellow status'
  - alert: ElasticsearchHealthyNodes
    expr: elasticsearch_cluster_health_number_of_nodes{alerting_required!='false'} 
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: elasticsearch_cluster_health_number_of_nodes%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Elasticsearch Healthy Nodes (instance {{ $labels.instance }})'
      description: 'Number Healthy Nodes less then number_of_nodes'
  - alert: ElasticsearchHealthyDataNodes
    expr: elasticsearch_cluster_health_number_of_data_nodes{alerting_required!='false'} 
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: elasticsearch_cluster_health_number_of_data_nodes%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Elasticsearch Healthy Data Nodes (instance {{ $labels.instance }})'
      description: 'Number Healthy Data Nodes less then number_of_data_nodes'
  - alert: ElasticsearchRelocationShards
    expr: elasticsearch_cluster_health_relocating_shards{alerting_required!='false'} > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: elasticsearch_cluster_health_relocating_shards%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Elasticsearch relocation shards (instance {{ $labels.instance }})'
      description: 'Number of relocation shards for 20 min'
  - alert: ElasticsearchInitializingShards
    expr: elasticsearch_cluster_health_initializing_shards{alerting_required!='false'} > 0
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: elasticsearch_cluster_health_initializing_shards%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Elasticsearch initializing shards (instance {{ $labels.instance }})'
      description: 'Number of initializing shards for 10 min'
  - alert: ElasticsearchUnassignedShards
    expr: elasticsearch_cluster_health_unassigned_shards{alerting_required!='false'} > 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: elasticsearch_cluster_health_unassigned_shards%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Elasticsearch unassigned shards (instance {{ $labels.instance }})'
      description: 'Number of unassigned shards for 2 min'
  - alert: ElasticsearchPendingTasks
    expr: elasticsearch_cluster_health_number_of_pending_tasks{alerting_required!='false'} > 0
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: elasticsearch_cluster_health_number_of_pending_tasks%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Elasticsearch pending tasks (instance {{ $labels.instance }})'
      description: 'Number of pending tasks for 10 min. Cluster works slowly.'
  - alert: ElasticsearchNoNewDocuments
    expr: rate(elasticsearch_indices_docs{alerting_required!='false',es_data_node='true'}[10m]) < 1
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: rate(elasticsearch_indices_docs%7Binstance='{{  $labels.instance  }}',es_data_node='true'%7D%5b10m%5d)
      value: '{{ $value }}'
      summary: 'Elasticsearch no new documents (instance {{ $labels.instance }})'
      description: 'No new documents for 10 min!'