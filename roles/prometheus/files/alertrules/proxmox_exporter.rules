groups:
- name: proxmox
  rules:
  - alert: Node_Storage_Free_Local
    expr: node_storage_free{storage_name="local"} < 35000000000
    for: 5m
    labels:
        severity: warning
    annotations:
        summary: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} is running low on memory"
        description: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} has less than 35 GB of disk space."
  - alert: Node_Storage_Free_PBS01_WOLF_LOCAL
    expr: node_storage_free{node_name="pve01",storage_name="pbs01.wolf.local"} < 500000000000
    for: 5m
    labels:
        severity: warning
    annotations:
        summary: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} is running low on memory"
        description: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} has less than 500 GB of disk space."
  - alert: Node_Storage_Free_PBS01_TUXIS_NL
    expr: node_storage_free{node_name="pve01",storage_name="pbs001.tuxis.nl"} < 100000000000
    for: 5m
    labels:
        severity: warning
    annotations:
        summary: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} is running low on memory"
        description: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} has less than 500 GB of disk space."
  - alert: Node_Storage_Free_PBS01_RAID5
    expr: node_storage_free{node_name="pve01",storage_name="raid5"} < 35000000000
    for: 5m
    labels:
        severity: warning
    annotations:
        summary: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} is running low on memory"
        description: "Node {{ $labels.instance }} on storage {{ $labels.storage_name }} has less than 35 GB of disk space."

