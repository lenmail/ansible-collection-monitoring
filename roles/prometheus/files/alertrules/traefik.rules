---
groups:
- name: traefik
  rules:
  - alert: "Traefik Certificate Expiration"
    expr: floor((sum without (hostname,ip_address,instance)(floor(traefik_tls_certs_not_after{alerting_required!='false'}) - time())) / 86400) < 7
    labels:
      severity: warning
    annotations:
      metric_name: floor((sum without (hostname,ip_address,instance)(floor(traefik_tls_certs_not_after{alerting_required!='false'}) - time())) / 86400) < 7
      value: "{{ $value }}"
      summary: Traefik Webserver certificate will expire in {{ $value }} for {{ $labels.cn }}
      description: "Traefik Webserver certificate will expire"
  - alert: "Traefik Backend Down"
    expr: traefik_service_server_up{alerting_required!='false'}  == 0
    for: 5m
    labels:
      severity: critical
    annotations:
      metric_name: traefik_service_server_up == 0
      value: "{{ $value }}"
      summary: Traefik service down (instance {{ $labels.instance }})
      description: "One Traefik services is down. Could be the non critical backup side"
  - alert: "Traefik HighHttp 4xx Error Rate on Service"
    expr: sum(rate(traefik_service_requests_total{alerting_required!='false',code=~"4.*"}[3m])) by (service) / sum(rate(traefik_service_requests_total[3m])) by (service) * 100 > 18
    for: 15m
    labels:
      severity: warning
    annotations:
      metric_name: sum(rate(traefik_service_requests_total{code=~"4.*"}[3m])) by (service) / sum(rate(traefik_service_requests_total[3m])) by (service) * 100
      value: "{{ $value }}"
      summary: Traefik high HTTP 4xx error rate service (instance {{ $labels.instance }})
      description: "Traefik service 4xx error rate is above 18%"
  - alert: "Traefik High Http 5xx Error Rate on Service"
    expr: sum(rate(traefik_service_requests_total{alerting_required!='false',code=~"5.*"}[3m])) by (service) / sum(rate(traefik_service_requests_total[3m])) by (service) * 100 > 25
    for: 5m
    labels:
      severity: warning
    annotations:
      metric_name: sum(rate(traefik_service_requests_total{code=~"5.*"}[3m])) by (service) / sum(rate(traefik_service_requests_total[3m])) by (service) * 100
      value: "{{ $value }}"
      summary: Traefik high HTTP 5xx error rate service (instance {{ $labels.instance }})
      description: "Traefik service 5xx error rate is above 5%"
