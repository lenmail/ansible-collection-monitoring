groups:
- name: mongodb_exporter
  rules:
  - alert: Prometheus Target Missing MongoDB Exporter
    expr: up{alerting_required!='false',job='mongo-exporter'} == 0
    for: 3m
    labels:
      severity: critical
      alert_scc: true
    annotations:
      metric_name: up%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Prometheus target missing MongoDB Exporter (instance {{ $labels.instance }})'
      scc_info: 'MongoDB Exporter auf Host {{ $labels.instance }} nicht mehr erreichbar. Bitte überprüfen, ob das System generell noch erreichbar ist. Falls ja mit systemctl status mongodb_exporter den Status des Dienstes überprüfen.'
  - alert: MongodbReplicationLag
    expr: avg(mongodb_replset_member_optime_date{alerting_required!='false',state='PRIMARY'}) - avg(mongodb_replset_member_optime_date{state='SECONDARY'}) > 10
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: avg(mongodb_replset_member_optime_date%7Binstance='{{  $labels.instance  }}',state='PRIMARY'%7D) - avg(mongodb_replset_member_optime_date%7Bstate='SECONDARY'%7D) 
      value: '{{ $value }}'
      summary: 'MongoDB replication lag (instance {{ $labels.instance }})'
      description: 'Mongodb replication lag is more than 10s'
  - alert: MongodbReplicationHeadroom
    expr: (avg(mongodb_replset_oplog_tail_timestamp{alerting_required!='false'} - mongodb_replset_oplog_head_timestamp) - (avg(mongodb_replset_member_optime_date{state='PRIMARY'}) - avg(mongodb_replset_member_optime_date{state='SECONDARY'}))) <= 0
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: (avg(mongodb_replset_oplog_tail_timestamp%7Binstance='{{  $labels.instance  }}'%7D - mongodb_replset_oplog_head_timestamp) - (avg(mongodb_replset_member_optime_date%7Binstance='{{  $labels.instance  }}', state='PRIMARY'%7D) - avg(mongodb_replset_member_optime_date%7Binstance='{{  $labels.instance  }}', state='SECONDARY'%7D)))
      value: '{{ $value }}'
      summary: 'MongoDB replication headroom (instance {{ $labels.instance }})'
      description: 'MongoDB replication headroom is <= 0'
  - alert: MongodbReplicationStatus3
    expr: mongodb_replset_member_state{alerting_required!='false'} == 3
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: mongodb_replset_member_state%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'MongoDB replication Status 3 (instance {{ $labels.instance }})'
      description: 'MongoDB Replication set member either perform startup self-checks, or transition from completing a rollback or resync'
  - alert: MongodbReplicationStatus6
    expr: mongodb_replset_member_state{alerting_required!='false'} == 6
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: mongodb_replset_member_state%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'MongoDB replication Status 6 (instance {{ $labels.instance }})'
      description: 'MongoDB Replication set member as seen from another member of the set, is not yet known'
  - alert: MongodbReplicationStatus8
    expr: mongodb_replset_member_state{alerting_required!='false'} == 8
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: mongodb_replset_member_state%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'MongoDB replication Status 8 (instance {{ $labels.instance }})'
      description: 'MongoDB Replication set member as seen from another member of the set, is unreachable'
  - alert: MongodbReplicationStatus9
    expr: mongodb_replset_member_state{alerting_required!='false'} == 9
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: mongodb_replset_member_state%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'MongoDB replication Status 9 (instance {{ $labels.instance }})'
      description: 'MongoDB Replication set member is actively performing a rollback. Data is not available for reads'
  - alert: MongodbReplicationStatus10
    expr: mongodb_replset_member_state{alerting_required!='false'} == 10
    for: 3m
    labels:
      severity: critical
    annotations:
      metric_name: mongodb_replset_member_state%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'MongoDB replication Status 10 (instance {{ $labels.instance }})'
      description: 'MongoDB Replication set member was once in a replica set but was subsequently removed'
  - alert: MongodbNumberCursorsOpen
    expr: mongodb_metrics_cursor_open{alerting_required!='false',state='total_open'} > 10000
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: mongodb_metrics_cursor_open%7Binstance='{{  $labels.instance  }}',state='total_open'%7D 
      value: '{{ $value }}'
      summary: 'MongoDB number cursors open (instance {{ $labels.instance }})'
      description: 'Too many cursors opened by MongoDB for clients (> 10k)'
  - alert: MongodbCursorsTimeouts
    expr: increase(mongodb_metrics_cursor_timed_out_total{alerting_required!='false'}[10m]) > 100
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: increase(mongodb_metrics_cursor_timed_out_total%7Binstance='{{  $labels.instance  }}'%7D%5b10m%5d)
      value: '{{ $value }}'
      summary: 'MongoDB cursors timeouts (instance {{ $labels.instance }})'
      description: 'Too many cursors are timing out'
  - alert: MongodbTooManyConnections
    expr: mongodb_connections{alerting_required!='false',state='current'} > 500
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: mongodb_connections%7Binstance='{{  $labels.instance  }}',state='current'%7D
      value: '{{ $value }}'
      summary: 'MongoDB too many connections (instance {{ $labels.instance }})'
      description: 'Too many connections'
  - alert: MongodbVirtualMemoryUsage
    expr: (sum(mongodb_memory{alerting_required!='false',type='virtual'}) BY (ip) / sum(mongodb_memory{type='mapped'}) BY (ip)) > 3
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: (sum(mongodb_memory%7Binstance='{{  $labels.instance  }}',type='virtual'%7D) BY (ip) / sum(mongodb_memory%7Btype='mapped'%7D) BY (ip))
      value: '{{ $value }}'
      summary: 'MongoDB virtual memory usage (instance {{ $labels.instance }})'
      description: 'High memory usage'
