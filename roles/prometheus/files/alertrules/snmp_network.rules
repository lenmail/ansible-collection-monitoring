#    ## Umrechung von Bytes  in Bits/s, da ifHighSpeed Bit/s 
#    expr: ((irate(ifHCOutOctets{snmpCommunity='DVAG'}[10m]) * 8 / 1024 / 1024) / (ifSpeed / 1e+6) * 100) > 90
#    for: 5m
#    labels:
#      severity: critical
#      alert_scc: true
  - alert: CPU Auslastung über 90 %
    expr: avg without(cpmCPUTotalIndex)(cpmCPUTotal1minRev{alerting_required!='false'} > 90)
    annotations:
      metric_name: avg without(cpmCPUTotalIndex)(cpmCPUTotal1minRev%7Binstance='{{  $labels.instance  }}'%7D) 
      description: 'CPU Auslastung auf dem Gerät {{ $labels.fqdn }} ist über {{ $value }}'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $value }}'
    for: 15m
    labels:
      severity: critical
      alert_scc: true
  - alert: Interface Down
    for: 5m
    expr: ifOperStatus{alerting_required!='false', mib!="fortigate_snmp", ifAlias=~'(TRUNK.+|sw.+|rt.+|wlc.+|fw.+|ap.+|adva.+|Link.+|hsmx.+|mon.+|fb.+|fex.+|FEX.+)'}  == 2 and ifAdminStatus  == 1
    annotations:
      metric_name: ifOperStatus%7Binstance='{{  $labels.instance  }}', ifIndex='{{  $labels.ifIndex }}'%7D
      description: 'Interface down {{ $labels.ifName  }} {{ $labels.ifDescr}} auf {{ $labels.fqdn}} Fehler.'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    labels:
      severity: critical
      alert_scc: true    
  # MON-4486
  - alert: Interface Down Fortigate
    for: 5m
    expr: ifOperStatus{alerting_required!='false', mib="fortigate_snmp", ifAlias=~'.+', ifName=~'port.+'}  == 2 and ifAdminStatus  == 1
    annotations:
      metric_name: ifOperStatus%7Binstance='{{  $labels.instance  }}', ifIndex='{{  $labels.ifIndex }}'%7D
      description: 'Interface down {{ $labels.ifName  }} {{ $labels.ifDescr}} auf {{ $labels.fqdn}} Fehler.'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    labels:
      severity: critical
      alert_scc: true    
  - alert: Temperatur Fehler
    expr: ciscoEnvMonTemperatureStatusValue{alerting_required!='false'} > ciscoEnvMonTemperatureThreshold
    annotations:
      metric_name: ciscoEnvMonTemperatureStatusValue%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Temperatur Fehler auf {{ $labels.fqdn}}'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true
  - alert: Power supply Fehler
    expr: ciscoEnvMonSupplyState{alerting_required!='false'} == 0
    annotations:
      metric_name: ciscoEnvMonSupplyState%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}}'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true
  - alert: Power supply Fehler
    expr: caemSupplyFailedComponent{alerting_required!='false'} == 2
    annotations:
      metric_name: caemSupplyFailedComponent%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}} \n Power supply component inputVoltage failure'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true
  - alert: Power supply Fehler
    expr: caemSupplyFailedComponent{alerting_required!='false'} == 3
    annotations:
      metric_name: caemSupplyFailedComponent%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}} \n Power supply component dcOutputVoltage failure'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true       
  - alert: Power supply Fehler
    expr: caemSupplyFailedComponent{alerting_required!='false'} == 4
    annotations:
      metric_name: caemSupplyFailedComponent%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}} \n Power supply component thermal failure'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true       
  - alert: Power supply Fehler
    expr: caemSupplyFailedComponent{alerting_required!='false'} == 5
    annotations:
      metric_name: caemSupplyFailedComponent%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}} \n Power supply component multiple failure'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true       
  - alert: Power supply Fehler
    expr: caemSupplyFailedComponent{alerting_required!='false'} == 6
    annotations:
      metric_name: caemSupplyFailedComponent%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}} \n Power supply component fan failure'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true       
  - alert: Power supply Fehler
    expr: caemSupplyFailedComponent{alerting_required!='false'} == 7
    annotations:
      metric_name: caemSupplyFailedComponent%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Power Supply fehler auf {{ $labels.fqdn}} \n Power supply component overvoltage failure'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true       
  - alert: Fan critical
    expr: ciscoEnvMonFanState{alerting_required!='false'} == 3
    annotations:
      metric_name: ciscoEnvMonFanState%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Fan Fehler auf {{ $labels.fqdn}}'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true 
  - alert: Fan critical
    expr: ciscoEnvMonFanState{alerting_required!='false'} != 1
    annotations:
      metric_name: ciscoEnvMonFanState%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Fan Fehler auf {{ $labels.fqdn}}'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $value }}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true 
  - alert: freier Speicher ist unter 5%
    expr: 100 * ciscoMemoryPoolFree{alerting_required!='false', mib='if_mib'} /  (ciscoMemoryPoolFree + ciscoMemoryPoolUsed) < 5
    annotations:
      metric_name: 100 * ciscoMemoryPoolFree%7Binstance='{{  $labels.instance  }}', mib='if_mib'%7D /  (ciscoMemoryPoolFree + ciscoMemoryPoolUsed)
      description: '{{ $labels.fqdn}} memory pool unter 9%'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
      value: '{{ $value }}'
    for: 15m
    labels:
      severity: warning
      alert_scc: true
  - alert: Cisco Switchstack Statusänderung 
    expr: changes(cswStackPortOperStatus{alerting_required!='false'}[5m]) == 2
    annotations:
      metric_name: changes(cswStackPortOperStatus%7Binstance='{{  $labels.instance  }}'%7D%5b5m%5d) 
      description: 'Switch {{ $labels.fqdn}} Port {{ $labels.ifIndex }} Switchstack Statusänderung'
      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren. Bitte prüfen ob 1 Switch offline ist oder hinzugefügt wurde.'
      value: '{{ $value }}'
    labels:
      severity: warning
      alert_scc: true
- name: snmp_exporter_fortigate
  rules:
  - alert: Fortigate check for active HA member
    expr: sum by (fqdn,hostname) (fgVpnTunEntOutOctets) == 0
    for: 5m
    labels:
      internal_alert: 'true'
    annotations:
      description: 'this alarm is only active on all standby fortigates. inhibation for all other vpn alerts will be activated'
  - alert: HA - UnSynchronized
    expr: fgHaStatsSyncStatus{alerting_required!='false',fqdn!~"fw-hof-reit-1og-1.infra.dvag.com|fw-mr-aff-1.infra.dvag.com|fw-mr-lg-1.infra.dvag.com|fw-mr-zlr-1.infra.dvag.com|fw-mr-vita-1.infra.dvag.com|fw-mr-bueck-1.infra.dvag.com|fw-ka-wgan-1.infra.dvag.com"} == 0
    annotations:
      metric_name: fgHaStatsSyncStatus%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'HA Status auf {{ $labels.fqdn}} UnSynchronized'
      scc_info: 'Prüfen warum die Firewall geschwenkt hat, SCC Informieren und fragen ob alle Systeme wie gewohnt arbeiten. Mail an netzwerk@dvag.com verschicken mit Information das die Firewall geschwenkt hat, warum und der Rückmeldung des SCCs'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true 
  - alert: HA - Disabled
    expr: fgHaAutoSync{alerting_required!='false'} == 0
    annotations:
      metric_name: fgHaAutoSync%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'HA Status auf {{ $labels.fqdn}} Disabled'
      scc_info: 'Prüfen warum die Firewall nicht HA fähig ist'
      value: '{{ $labels.fqdn}}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true
  - alert: Fortigate HW Sensor Failure
    expr: fgHwSensorEntAlarmStatus == 1
    annotations:
      metric_name: fgHwSensorEntAlarmStatus%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'HW Sensor mit ID {{ $labels.fgHwSensorEntIndex }} hat einen Fehler. Bitte direkt auf dem Gerät{{ $labels.fqdn }} prüfen.'
      scc_info: 'Bitte direkt auf dem Gerät {{ $labels.fqdn }} prüfen.'
      value: '{{ $labels.fqdn }}'
    for: 10m
    labels:
      severity: critical
      alert_scc: true 
  - alert: Fortigate CPU Usage
    expr: fgSysCpuUsage{alerting_required!='false'} > 95
    annotations:
      metric_name: fgSysCpuUsage%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'CPU Load auf {{ $labels.fqdn}} critical'
      scc_info: 'Prüfen woher die CPU Last kommt, z.B. ist mehr Last auf den Interfaces, gibt es mehr Connections oder einen Prozess auf der Firewall der sehr viel CPU benötigt. SCC und Netzwerk per Mail Informieren'
      value: '{{ $value }}'
    for: 10m
    labels:
      severity: critical
      alert_scc: true 
  - alert: Fortigate Memory Usage
    expr: fgSysMemUsage{alerting_required!='false'} > 75
    annotations:
      metric_name: fgSysMemUsage%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Memory Load auf {{ $labels.fqdn}} critical'
      scc_info: 'Memory usage on Fortinet is more than 80% during the last three checks'
      value: '{{ $value }}'
    for: 10m
    labels:
      severity: critical
      alert_scc: true 
  - alert: Fortigate Disk Usage
    expr: fgSysDiskUsage{alerting_required!='false'} / fgSysDiskCapacity * 100 > 90
    annotations:
      metric_name: fgSysDiskUsage%7Binstance='{{  $labels.instance  }}'%7D / fgSysDiskCapacity * 100 
      description: 'Disk Usage auf {{ $labels.fqdn}} höher als {{ $value }}'
      scc_info: 'Disk usage on Fortinet is more than 90%'
      value: '{{ $value }}'
    for: 3m
    labels:
      severity: critical
      alert_scc: true
- name: snmp_exporter_pdu
  rules:
  - alert: PDU Temperatur zu hoch
    expr: e3IpmSensorTemperatureCelsius{alerting_required!='false'} / 10 > 36
    annotations:
      metric_name: e3IpmSensorTemperatureCelsius%7Binstance='{{  $labels.instance  }}'%7D / 10 
      description: 'Temperatur auf PDU {{ $labels.fqdn }} bei {{ $value }}.'
      scc_info: 'Bitte RZ-Team informieren'
      value: '{{ $value }}'
    labels:
      severity: critical
      alert_scc: true
  - alert: PDU Temperatur zu hoch
    expr: e3IpmSensorTemperatureCelsius{alerting_required!='false'} / 10 > 36
    annotations:
      metric_name: e3IpmSensorTemperatureCelsius%7Binstance='{{  $labels.instance  }}'%7D / 10 
      description: 'Temperatur auf PDU {{ $labels.fqdn }} bei {{ $value }}.'
      scc_info: 'Bitte RZ-Team informieren'
      value: '{{ $value }}'
    labels:
      severity: critical
      alert_scc: true
- name: snmp_exporter_temperatur_wien
  rules:
  - alert: Wien Temperatur Sensor erhöht
    expr: snmp_comet_temperature > 40
    annotations:
      metric_name: snmp_comet_temperature%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Temperatur Sensor auf {{ $labels.fqdn}} bei {{ $value }}'
      scc_info: 'Temperatur Problem im Wien RZ. Bitte entweder Rainer Pistl-Syha (+43676884005700) oder wenn nicht erreichbar Daniel Herzog (+436769601152) anrufen.'
      value: '{{ $value }}'
    for: 10m
    labels:
      severity: critical
      alert_scc: true
- name: snmp_exporter_wdm_pandacom
  rules:
  - alert: WDM Pandacom FC Transceiver TX power event
    annotations:
      description: "Port { $labels.speedDuallineFCPortIndex}} auf {{ $labels.fqdn}} zu geringer Sendepegel."
      scc_info: "Sendepegel auf DWDM Fiberchannel Kanal zu Gering. Bitte SAN Team informieren und Prüfen ob es im Fiberchannel bzw. Storagebereich Probleme gibt"
      value: "{{ $value}}"
    expr: speedDuallineFCPortXCVDMITxLowAlarm == 0
    for: 15m
    labels:
      severity: critical
      alert_scc: false
  - alert: WDM Pandacom FC Transceiver temperature event
    annotations:
      description: "Port { $labels.speedDuallineFCPortIndex}} auf {{ $labels.fqdn}} zu geringe Temperatur."
      scc_info: "Temperatur auf DWDM Fiberchannel Kanal zu Gering. Bitte SAN Team informieren und Prüfen ob es im Fiberchannel bzw. Storagebereich Probleme gibt"
      value: "{{ $value}}"
    expr: speedDuallineFCPortXCVTempHighAlarm == 0
    for: 15m
    labels:
      severity: critical
      alert_scc: false
  - alert: WDM Pandacom 10G Transceiver RX power event
    annotations:
      description: "Port { $labels.speedDuallineFCPortIndex}} auf {{ $labels.fqdn}} zu geringer Empfangspegel."
      scc_info: "Empfangspegel auf DWDM Netzwerk Kanal zu Gering. Bitte Netzwerk Team informieren und Prüfen ob es Probleme im Onlinesystem gibt"
      value: "{{ $value}}"
    expr: speedDualline10GPortXCVDMIRxPowerAlarm == 0
    for: 15m
    labels:
      severity: critical
      alert_scc: false
  - alert: WDM Pandacom 10G Transceiver TX power event
    annotations:
      description: "Port { $labels.speedDuallineFCPortIndex}} auf {{ $labels.fqdn}} zu geringer Sendepegel."
      scc_info: "Sendepegel auf DWDM Netzwerk Kanal zu Gering. Bitte Netzwerk Team informieren und Prüfen ob es Probleme im Onlinesystem gibt"
      value: "{{ $value}}"
    expr: speedDualline10GPortXCVDMITxLowAlarm == 0
    for: 15m
    labels:
      severity: critical
      alert_scc: false
  - alert: WDM Pandacom 10G Transceiver temperature event
    annotations:
      description: "Port { $labels.speedDuallineFCPortIndex}} auf {{ $labels.fqdn}} zu geringe Temperatur."
      scc_info: "Temperatur auf DWDM Netzwerk Kanal zu Gering. Bitte Netzwerk Team informieren und Prüfen ob es Probleme im Onlinesystem gibt"
      value: "{{ $value}}"
    expr: speedDualline10GPortXCVTempHighAlarm == 0
    for: 15m
    labels:
      severity: critical
      alert_scc: false