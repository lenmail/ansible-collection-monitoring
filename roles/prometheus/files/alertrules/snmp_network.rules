#      description: 'Auf Port {{ $labels.ifAlias}} beträgt die Auslastung über 90% der maximalen Port Geschwindigkeit'
#      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
#      value: '{{ $value }}'
#    ## Umrechung von Bytes  in Bits/s, da ifHighSpeed Bit/s 
#    expr: ((irate(ifHCInOctets{snmpCommunity='DVAG'}[10m]) * 8 / 1024 / 1024) / (ifSpeed / 1e+6) * 100) > 90
#    for: 5m
#    labels:
#      severity: critical
#      alert_scc: true
#  - alert: Ausgehender Traffic über 90% des Port Limits
#    annotations:
      #    metric_name: ((irate(ifHCInOctets{snmpCommunity='DVAG'}[10m]) * 8 / 1024 / 1024) / (ifSpeed / 1e+6) * 100) 
#      description: 'Auf Port {{ $labels.ifAlias}} beträgt die Auslastung über 90% der maximalen Port Geschwindigkeit'
#      scc_info: 'Bitte passenden Dienstleister anhand des Info Textes oben im Ticket informieren'
