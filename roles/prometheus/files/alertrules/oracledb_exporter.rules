  - alert: 'OracleDB Count Sessions - Warning'
    expr: dvag_oracle_active_session_count >= dvag_oracle_active_session_warning_treshhold
    labels:
      severity: warning
      alert_scc: false
    annotations:
      metric_name: dvag_oracle_active_session_count%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Number of Oracle Server Connections too high'
      scc_info: 'Ticket bei TS oder DBA erstellen. Falls Produktion -> Zusätzlich TS oder DBA informieren.'
  - alert: 'OracleDB Count Sessions - Critical'
    expr: dvag_oracle_active_session_count >= dvag_oracle_active_session_critical_treshhold
    labels:
      severity: critical
      alert_scc: true
    annotations:
