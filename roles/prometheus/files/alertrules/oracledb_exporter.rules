  - alert: 'OracleDB Check Standby Gap - Warning'
    expr: dvag_oracle_standby_applylag_value >= dvag_oracle_standby_applylag_warning_treshhold
    labels:
      severity: warning
      alert_scc: true
    annotations:
      metric_name: dvag_oracle_standby_applylag_value%7Binstance='{{  $labels.instance  }}'%7D 
      description: 'Das Gap zwischen Primary DB und Standby DB ist zu hoch'
      scc_info: 'Ticket bei DBA erstellen. Falls Produktion -> Zusätzlich sofort DBA informieren. Außerhalb der Kernzeit bitte DBA Bereitschaft anrufen.'
  - alert: 'OracleDB Check Standby Gap - Critical'
