      value: '{{ $value }}'
      summary: 'Response Queue Problem auf Host {{ $labels.instance }} Datenbank {{ $labels.database }}'
      scc_info: 'Ticket an DBAs / Anruf ausserhalb der Betriebszeit nicht notwendig'
