groups:
- name: kubernetes
  rules:
  - alert: KubernetesNodeReady
    expr: kube_node_status_condition{alerting_required='yes',condition='Ready',status='true'} == 0
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_node_status_condition%7Binstance='{{  $labels.instance  }}', alerting_required='yes',condition='Ready',status='true'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes Node ready (instance {{ $labels.instance }})'
      description: 'Node {{ $labels.node }} has been unready for a long time'
  - alert: KubernetesMemoryPressure
    expr: kube_node_status_condition{alerting_required='yes',condition='MemoryPressure',status='true'} == 1
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_node_status_condition%7Binstance='{{  $labels.instance  }}', alerting_required='yes',condition='MemoryPressure',status='true'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes memory pressure (instance {{ $labels.instance }})'
      description: '{{ $labels.node }} has MemoryPressure condition'
  - alert: KubernetesDiskPressure
    expr: kube_node_status_condition{alerting_required='yes',condition='DiskPressure',status='true'} == 1
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_node_status_condition%7Binstance='{{  $labels.instance  }}', alerting_required='yes',condition='DiskPressure',status='true'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes disk pressure (instance {{ $labels.instance }})'
      description: '{{ $labels.node }} has DiskPressure condition'
  - alert: KubernetesOutOfDisk
    expr: kube_node_status_condition{alerting_required='yes',condition='OutOfDisk',status='true'} == 1
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_node_status_condition%7Binstance='{{  $labels.instance  }}', alerting_required='yes',condition='OutOfDisk',status='true'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes out of disk (instance {{ $labels.instance }})'
      description: '{{ $labels.node }} has OutOfDisk condition'
  - alert: KubernetesJobFailed
    expr: kube_job_status_failed{alerting_required='yes'} > 0
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_job_status_failed%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D
      value: '{{ $value }}'
      summary: 'Kubernetes Job failed (instance {{ $labels.instance }})'
      description: 'Job {{$labels.namespace}}/{{$labels.exported_job}} failed to complete'
  - alert: KubernetesCronjobSuspended
    expr: kube_cronjob_spec_suspend{alerting_required='yes'} != 0
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_cronjob_spec_suspend%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes CronJob suspended (instance {{ $labels.instance }})'
      description: 'CronJob {{ $labels.namespace }}/{{ $labels.cronjob }} is suspended'
  - alert: KubernetesPersistentvolumeclaimPending
    expr: kube_persistentvolumeclaim_status_phase{alerting_required='yes',phase='Pending'} == 1
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_persistentvolumeclaim_status_phase%7Binstance='{{  $labels.instance  }}', alerting_required='yes',phase='Pending'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes PersistentVolumeClaim pending (instance {{ $labels.instance }})'
      description: 'PersistentVolumeClaim {{ $labels.namespace }}/{{ $labels.persistentvolumeclaim }} is pending'
  - alert: KubernetesVolumeOutOfDiskSpace
    expr: kubelet_volume_stats_available_bytes{alerting_required='yes'} / kubelet_volume_stats_capacity_bytes * 100 < 10
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kubelet_volume_stats_available_bytes%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D / kubelet_volume_stats_capacity_bytes * 100 
      value: '{{ $value }}'
      summary: 'Kubernetes Volume out of disk space (instance {{ $labels.instance }})'
      description: 'Volume is almost full (< 10% left)'
  - alert: KubernetesVolumeFullInFourDays
    expr: predict_linear(kubelet_volume_stats_available_bytes{alerting_required='yes'}[6h], 4 * 24 * 3600) < 0
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: predict_linear(kubelet_volume_stats_available_bytes{instance='{{  $labels.instance  }}', alerting_required='yes'}[6h], 4 * 24 * 3600)
      value: '{{ $value }}'
      summary: 'Kubernetes Volume full in four days (instance {{ $labels.instance }})'
      description: '{{ $labels.namespace }}/{{ $labels.persistentvolumeclaim }} is expected to fill up within four days. Currently {{ $value | humanize }}% is available.'
  - alert: KubernetesPersistentvolumeError
    expr: kube_persistentvolume_status_phase{alerting_required='yes',phase=~'Failed|Pending',job='kube-state-metrics'} > 0
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_persistentvolume_status_phase%7Binstance='{{  $labels.instance  }}', alerting_required='yes',phase=~'Failed|Pending',job='kube-state-metrics'%7D
      value: '{{ $value }}'
      summary: 'Kubernetes PersistentVolume error (instance {{ $labels.instance }})'
      description: 'Persistent volume is in bad state'
  - alert: KubernetesStatefulsetDown
    expr: (kube_statefulset_status_replicas_ready{alerting_required='yes'} / kube_statefulset_status_replicas_current) != 1
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: (kube_statefulset_status_replicas_ready{instance='{{  $labels.instance  }}', alerting_required='yes'} / kube_statefulset_status_replicas_current) 
      value: '{{ $value }}'
      summary: 'Kubernetes StatefulSet down (instance {{ $labels.instance }})'
      description: 'A StatefulSet went down'
  - alert: KubernetesHpaScalingAbility
    expr: kube_hpa_status_condition{alerting_required='yes',condition='false', status='AbleToScale'} == 1
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_hpa_status_condition%7Binstance='{{  $labels.instance  }}', alerting_required='yes',condition='false', status='AbleToScale'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes HPA scaling ability (instance {{ $labels.instance }})'
      description: 'Pod is unable to scale'
  - alert: KubernetesHpaMetricAvailability
    expr: kube_hpa_status_condition{alerting_required='yes',condition='false', status='ScalingActive'} == 1
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_hpa_status_condition%7Binstance='{{  $labels.instance  }}', alerting_required='yes',condition='false', status='ScalingActive'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes HPA metric availability (instance {{ $labels.instance }})'
      description: 'HPA is not able to colelct metrics'
  - alert: KubernetesHpaScaleCapability
    expr: kube_hpa_status_desired_replicas{alerting_required='yes'} >= kube_hpa_spec_max_replicas
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_hpa_status_desired_replicas%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D >= kube_hpa_spec_max_repl
      value: '{{ $value }}'
      summary: 'Kubernetes HPA scale capability (instance {{ $labels.instance }})'
      description: 'The maximum number of desired Pods has been hit'
  - alert: KubernetesPodNotHealthy
    expr: min_over_time(sum by (namespace, pod) (kube_pod_status_phase{alerting_required='yes',phase=~'Pending|Unknown|Failed'})[1h:])
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: min_over_time(sum by (namespace, pod) (kube_pod_status_phase{instance='{{  $labels.instance  }}', alerting_required='yes',phase=~'Pending|Unknown|Failed'})[1h:])
      value: '{{ $value }}'
      summary: 'Kubernetes Pod not healthy (instance {{ $labels.instance }})'
      description: 'Pod has been in a non-ready state for longer than an hour.'
  - alert: KubernetesPodCrashLooping
    expr: rate(kube_pod_container_status_restarts_total{alerting_required='yes'}[15m]) * 60 * 5 > 5
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: rate(kube_pod_container_status_restarts_total{instance='{{  $labels.instance  }}', alerting_required='yes'}[15m]) * 60 * 5
      value: '{{ $value }}'
      summary: 'Kubernetes pod crash looping (instance {{ $labels.instance }})'
      description: 'Pod {{ $labels.pod }} is crash looping'
  - alert: KubernetesReplicassetMismatch
    expr: kube_replicaset_spec_replicas{alerting_required='yes'} != kube_replicaset_status_ready_replicas
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_replicaset_spec_replicas%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes ReplicasSet mismatch (instance {{ $labels.instance }})'
      description: 'Deployment Replicas mismatch'
  - alert: KubernetesDeploymentReplicasMismatch
    expr: kube_deployment_spec_replicas{alerting_required='yes'} != kube_deployment_status_replicas_available
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_deployment_spec_replicas%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D
      value: '{{ $value }}'
      summary: 'Kubernetes Deployment replicas mismatch (instance {{ $labels.instance }})'
      description: 'Deployment Replicas mismatch'
  - alert: KubernetesStatefulsetReplicasMismatch
    expr: kube_statefulset_status_replicas_ready{alerting_required='yes'} != kube_statefulset_status_replicas
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: kube_statefulset_status_replicas_ready%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes StatefulSet replicas mismatch (instance {{ $labels.instance }})'
      description: 'A StatefulSet has not matched the expected number of replicas for longer than 15 minutes.'
  - alert: KubernetesDeploymentGenerationMismatch
    expr: kube_deployment_status_observed_generation{alerting_required='yes'} != kube_deployment_metadata_generation
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_deployment_status_observed_generation%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D
      value: '{{ $value }}'
      summary: 'Kubernetes Deployment generation mismatch (instance {{ $labels.instance }})'
      description: 'A Deployment has failed but has not been rolled back.'
  - alert: KubernetesStatefulsetGenerationMismatch
    expr: kube_statefulset_status_observed_generation{alerting_required='yes'} != kube_statefulset_metadata_generation
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_statefulset_status_observed_generation%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D 
      value: '{{ $value }}'
      summary: 'Kubernetes StatefulSet generation mismatch (instance {{ $labels.instance }})'
      description: 'A StatefulSet has failed but has not been rolled back.'
  - alert: KubernetesStatefulsetUpdateNotRolledOut
    expr: max without (revision) (kube_statefulset_status_current_revision unless kube_statefulset_status_update_revision{alerting_required='yes'}) * (kube_statefulset_replicas != kube_statefulset_status_replicas_updated)
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: max without (revision) (kube_statefulset_status_current_revision unless kube_statefulset_status_update_revision{instance='{{  $labels.instance  }}', alerting_required='yes'}) * (kube_statefulset_replicas
      value: '{{ $value }}'
      summary: 'Kubernetes StatefulSet update not rolled out (instance {{ $labels.instance }})'
      description: 'StatefulSet update has not been rolled out.'
  - alert: KubernetesDaemonsetRolloutStuck
    expr: kube_daemonset_status_number_ready{alerting_required='yes'} / kube_daemonset_status_desired_number_scheduled * 100 < 100 or kube_daemonset_status_desired_number_scheduled - kube_daemonset_status_current_number_scheduled > 0
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_daemonset_status_number_ready%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D / kube_daemonset_status_desired_number_scheduled * 100 
      value: '{{ $value }}'
      summary: 'Kubernetes DaemonSet rollout stuck (instance {{ $labels.instance }})'
      description: 'Some Pods of DaemonSet are not scheduled or not ready'
  - alert: KubernetesDaemonsetMisscheduled
    expr: kube_daemonset_status_number_misscheduled{alerting_required='yes'} > 0
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_daemonset_status_number_misscheduled%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D
      value: '{{ $value }}'
      summary: 'Kubernetes DaemonSet misscheduled (instance {{ $labels.instance }})'
      description: 'Some DaemonSet Pods are running where they are not supposed to run'
  - alert: KubernetesCronjobTooLong
    expr: time() - kube_cronjob_next_schedule_time{alerting_required='yes'} > 3600
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: time() - kube_cronjob_next_schedule_time{alerting_required='yes'} > 
      value: '{{ $value }}'
      summary: 'Kubernetes CronJob too long (instance {{ $labels.instance }})'
      description: 'CronJob {{ $labels.namespace }}/{{ $labels.cronjob }} is taking more than 1h to complete.'
  - alert: KubernetesJobCompletion
    expr: kube_job_spec_completions{alerting_required='yes'} - kube_job_status_succeeded > 0 or kube_job_status_failed > 0
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: kube_job_spec_completions%7Binstance='{{  $labels.instance  }}', alerting_required='yes'%7D - kube_job_status_succeeded 
      value: '{{ $value }}'
      summary: 'Kubernetes job completion (instance {{ $labels.instance }})'
      description: 'Kubernetes Job failed to complete'
  - alert: KubernetesApiServerErrors
    expr: sum(rate(apiserver_request_count{alerting_required='yes',job='apiserver',code=~'^(?:5..)$'}[2m])) / sum(rate(apiserver_request_count{job='apiserver'}[2m])) * 100 > 3
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: sum(rate(apiserver_request_count{instance='{{  $labels.instance  }}', alerting_required='yes',job='apiserver',code=~'^(?:5..)$'}[2m])) / sum(rate(apiserver_request_count{job='apiserver'}[2m])) * 100 
      value: '{{ $value }}'
      summary: 'Kubernetes API server errors (instance {{ $labels.instance }})'
      description: 'Kubernetes API server is experiencing high error rate'
  - alert: KubernetesApiClientErrors
    expr: (sum(rate(rest_client_requests_total{alerting_required='yes',code=~'(4|5)..'}[2m])) by (instance, job) / sum(rate(rest_client_requests_total[2m])) by (instance, job)) * 100 > 1
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: (sum(rate(rest_client_requests_total{instance='{{  $labels.instance  }}', alerting_required='yes',code=~'(4|5)..'}[2m])) by (instance, job) / sum(rate(rest_client_requests_total[2m])) by (instance, job)) * 100
      value: '{{ $value }}'
      summary: 'Kubernetes API client errors (instance {{ $labels.instance }})'
      description: 'Kubernetes API client is experiencing high error rate'
  - alert: KubernetesClientCertificateExpiresNextWeek
    expr: apiserver_client_certificate_expiration_seconds_count{alerting_required='yes',job='apiserver'} > 0 and histogram_quantile(0.01, sum by (job, le) (rate(apiserver_client_certificate_expiration_seconds_bucket{job='apiserver'}[5m]))) < 7*24*60*60
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: apiserver_client_certificate_expiration_seconds_count%7Binstance='{{  $labels.instance  }}', alerting_required='yes',job='apiserver'} > 0 and histogram_quantile(0.01, sum by (job, le) (rate(apiserver_client_certificate_expiration_seconds_bucket{job='apiserver'%7D[5m]))) < 7*24*6
      value: '{{ $value }}'
      summary: 'Kubernetes client certificate expires next week (instance {{ $labels.instance }})'
      description: 'A client certificate used to authenticate to the apiserver is expiring next week.'
  - alert: KubernetesClientCertificateExpiresSoon
    expr: apiserver_client_certificate_expiration_seconds_count{alerting_required='yes',job='apiserver'} > 0 and histogram_quantile(0.01, sum by (job, le) (rate(apiserver_client_certificate_expiration_seconds_bucket{job='apiserver'}[5m]))) < 24*60*60
    for: 3m
    labels:
      severity: error
    annotations:
      metric_name: apiserver_client_certificate_expiration_seconds_count%7Binstance='{{  $labels.instance  }}', alerting_required='yes',job='apiserver'} > 0 and histogram_quantile(0.01, sum by (job, le) (rate(apiserver_client_certificate_expiration_seconds_bucket{job='apiserver'%7D[5m]))) < 24*6
      value: '{{ $value }}'
      summary: 'Kubernetes client certificate expires soon (instance {{ $labels.instance }})'
      description: 'A client certificate used to authenticate to the apiserver is expiring in less than 24.0 hours.'
  - alert: KubernetesApiServerLatency
    expr: histogram_quantile(0.99, sum(apiserver_request_latencies_bucket{alerting_required='yes',verb!~'CONNECT|WATCHLIST|WATCH|PROXY'}) WITHOUT (instance, resource)) / 1e+06 > 1
    for: 3m
    labels:
      severity: standard
    annotations:
      metric_name: histogram_quantile(0.99, sum(apiserver_request_latencies_bucket{instance='{{  $labels.instance  }}', alerting_required='yes',verb!~'CONNECT|WATCHLIST|WATCH|PROXY'}) WITHOUT (instance, resource)) / 1e+06
      value: '{{ $value }}'
      summary: 'Kubernetes API server latency (instance {{ $labels.instance }})'
      description: 'Kubernetes API server has a 99th percentile latency of {{ $value }} seconds for {{ $labels.verb }} {{ $labels.resource }}.'
