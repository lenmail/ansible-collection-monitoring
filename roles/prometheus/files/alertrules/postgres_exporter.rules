groups:
- name: postgres_exporter
  rules:
  - alert: PostgresqlDown
    expr: pg_up{alerting_required!='false'} == 0
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_up%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql down (instance {{ $labels.instance }})'
      description: 'Postgresql instance is down'
  - alert: PostgresqlRestarted
    expr: time() - pg_postmaster_start_time_seconds{alerting_required!='false'} < 60
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: time() - pg_postmaster_start_time_seconds%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql restarted (instance {{ $labels.instance }})'
      description: 'Postgresql restarted'
  - alert: PostgresqlArchiveTimeout
    expr: pg_settings_archive_timeout_seconds{alerting_required!='false',product='postgres'} > 3600 or pg_settings_archive_timeout_seconds{alerting_required!='false',product='postgres'} == 0
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_archive_timeout_seconds%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Archive Timeout'
      description: 'Postgresql Archive Timeout too high VALUE = {{ $value }}'
  - alert: PostgresqlSettingsAuthenticationTimeout
    expr: pg_settings_authentication_timeout_seconds{alerting_required!='false'} == 0 or pg_settings_authentication_timeout_seconds{alerting_required!='false'} > 60
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_authentication_timeout_seconds%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Settings Authentication Timeout'
      description: 'Postgresql Settings Authentication Timeout too high VALUE = {{ $value }}'
  - alert: PostgresqlSettingsLogConnections
    expr: pg_settings_log_connections{alerting_required!='false',product='postgres'} == 0
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_log_connections%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Settings Log Connections'
      description: 'Postgresql Settings Log Connections are off VALUE = {{ $value }}'
  - alert: PostgresqlSettingsLogDisconnections
    expr: pg_settings_log_disconnections{alerting_required!='false',product='postgres'} == 0
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_log_disconnections%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Settings Log Disconnections'
      description: 'Postgresql Settings Log Disconnections are off VALUE = {{ $value }}'
  - alert: PostgresqlSettingsLogLockWaits
    expr: pg_settings_log_lock_waits{alerting_required!='false'} == 1
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_log_lock_waits%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Settings Log Lock Waits'
      description: 'Postgresql Settings Log Lock is waiting VALUE = {{ $value }}' 
  - alert: PostgresqlSettingsLogStatementStats
    expr: pg_settings_log_statement_stats{alerting_required!='false'} == 1
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_log_statement_stats%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Settings Log Statement Stats'
      description: 'Postgresql Settings Log Statement Stats are on VALUE = {{ $value }}'
  - alert: PostgresqlSettingsMaxStandbyArchiveDelaySeconds
    expr: pg_settings_max_standby_archive_delay_seconds{alerting_required!='false'} == 0 or pg_settings_max_standby_archive_delay_seconds{alerting_required!='false'} > 900
    for: 3m
    labels:
      alert_scc: true
      severity: critical
    annotations:
      metric_name: pg_settings_max_standby_archive_delay_seconds%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql Settings Max Standby Archive Delay Seconds Eq 0'
      description: 'Postgresql Settings Max Standby Archive Delay is 0 VALUE = {{ $value }}'
  - alert: PostgresqlExporterError
    expr: pg_exporter_last_scrape_error{alerting_required!='false'} > 0
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: pg_exporter_last_scrape_error%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Postgresql exporter error (instance {{ $labels.instance }})'
      description: 'Postgresql exporter is showing errors. A query may be buggy in query.yaml'
  - alert: PostgresqlTableNotVaccumed
    expr: time() - pg_stat_user_tables_last_autovacuum{alerting_required!='false'} > 60 * 60 * 24
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: time() - pg_stat_user_tables_last_autovacuum%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Postgresql table not vaccumed (instance {{ $labels.instance }})'
      description: 'Table has not been vaccum for 24 hours'
  - alert: PostgresqlTableNotAnalyzed
    expr: time() - pg_stat_user_tables_last_autoanalyze{alerting_required!='false'} > 60 * 60 * 24
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: time() - pg_stat_user_tables_last_autoanalyze%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Postgresql table not analyzed (instance {{ $labels.instance }})'
      description: 'Table has not been analyzed for 24 hours'
  - alert: PostgresqlTooManyConnections
    expr: sum by (datname) (pg_stat_activity_count{alerting_required!='false',datname!~'template.*|postgres'}) > pg_settings_max_connections * 0.9
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: sum by (datname) (pg_stat_activity_count%7Binstance='{{  $labels.instance  }}',datname!%7E'template.*%7Cpostgres'%7D)
      value: '{{ $value }}'
      summary: 'Postgresql too many connections (instance {{ $labels.instance }})'
      description: 'PostgreSQL instance has too many connections'
  - alert: PostgresqlDeadLocks
    expr: rate(pg_stat_database_deadlocks{alerting_required!='false',datname!~'template.*|postgres'}[5m]) > 0
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: rate(pg_stat_database_deadlocks%7Binstance='{{  $labels.instance  }}',datname!%7E'template.*%7Cpostgres'%7D%5b5m%5d)
      value: '{{ $value }}'
      summary: 'Postgresql dead locks (instance {{ $labels.instance }})'
      description: 'PostgreSQL has dead-locks'
  - alert: PostgresqlSlowQueries
    expr: pg_slow_queries{alerting_required!='false'} > 0
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: pg_slow_queries%7Binstance='{{  $labels.instance  }}'%7D
      value: '{{ $value }}'
      summary: 'Postgresql slow queries (instance {{ $labels.instance }})'
      description: 'PostgreSQL executes slow queries'
  - alert: PostgresqlHighRollbackRate
    expr: rate(pg_stat_database_xact_rollback{alerting_required!='false',datname!~'template.*'}[3m]) / rate(pg_stat_database_xact_commit{datname!~'template.*'}[3m]) > 0.02
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: rate(pg_stat_database_xact_rollback%7Binstance='{{  $labels.instance  }}',datname!%7E'template.*'%7D%5b3m%5d) / rate(pg_stat_database_xact_commit{datname!%7E'template.*'%7D%5b3m%5d)
      value: '{{ $value }}'
      summary: 'Postgresql high rollback rate (instance {{ $labels.instance }})'
      description: 'Ratio of transactions being aborted compared to committed is > 2 %'
  - alert: PostgresqlCommitRateHigh
    expr: rate(pg_stat_database_xact_commit{alerting_required!='false'}[5m]) > 150
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: rate(pg_stat_database_xact_commit%7Binstance='{{  $labels.instance  }}'%7D%5b5m%5d) 
      value: '{{ $value }}'
      summary: 'Postgresql commit rate low (instance {{ $labels.instance }})'
      description: 'Postgres seems to be processing very few transactions'
  - alert: PostgresqlLowXidConsumption
    expr: rate(pg_txid_current{alerting_required!='false'}[5m]) < 5
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: rate(instance='{{  $labels.instance  }}', pg_txid_current%7B%7D%5b5m%5d)
      value: '{{ $value }}'
      summary: 'Postgresql low XID consumption (instance {{ $labels.instance }})'
      description: 'Postgresql seems to be consuming transaction IDs very slowly'
  - alert: PostgresqllowXlogConsumption
    expr: rate(pg_xlog_position_bytes{alerting_required!='false'}[5m]) < 100
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: rate(instance='{{  $labels.instance  }}', pg_xlog_position_bytes%7B%7D%5b5m%5d)
      value: '{{ $value }}'
      summary: 'Postgresqllow XLOG consumption (instance {{ $labels.instance }})'
      description: 'Postgres seems to be consuming XLOG very slowly'
  - alert: PostgresqlWaleReplicationStopped
    expr: rate(pg_xlog_position_bytes{alerting_required!='false'}[5m]) == 0
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: rate(pg_xlog_position_bytes%7Binstance='{{  $labels.instance  }}'%7D%5b5m%5d) 
      value: '{{ $value }}'
      summary: 'Postgresql WALE replication stopped (instance {{ $labels.instance }})'
      description: 'WAL-E replication seems to be stopped'
  - alert: PostgresqlHighRateStatementTimeout
    expr: rate(postgresql_errors_total{alerting_required!='false',type='statement_timeout'}[5m]) > 3
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: rate(postgresql_errors_total%7Binstance='{{  $labels.instance  }}',type='statement_timeout'%7D%5b5m%5d)
      value: '{{ $value }}'
      summary: 'Postgresql high rate statement timeout (instance {{ $labels.instance }})'
      description: 'Postgres transactions showing high rate of statement timeouts'
  - alert: PostgresqlHighRateDeadlock
    expr: rate(postgresql_errors_total{alerting_required!='false',type='deadlock_detected'}[5m]) * 60 > 1
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: rate(postgresql_errors_total%7Binstance='{{  $labels.instance  }}',type='deadlock_detected'%7D%5b5m%5d) * 60
      value: '{{ $value }}'
      summary: 'Postgresql high rate deadlock (instance {{ $labels.instance }})'
      description: 'Postgres detected deadlocks'
  - alert: PostgresqlUnusedReplicationSlot
    expr: pg_replication_slots_active{alerting_required!='false'} == 0
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: pg_replication_slots_active%7Binstance='{{  $labels.instance  }}'%7D 
      value: '{{ $value }}'
      summary: 'Postgresql unused replication slot (instance {{ $labels.instance }})'
      description: 'Unused Replication Slots'
  - alert: PostgresqlTooManyDeadTuples
    expr: ((pg_stat_user_tables_n_dead_tup{alerting_required!='false'} > 10000) / (pg_stat_user_tables_n_live_tup + pg_stat_user_tables_n_dead_tup)) >= 0.1 unless ON(instance) (pg_replication_is_replica == 1)
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: ((pg_stat_user_tables_n_dead_tup%7Binstance='{{  $labels.instance  }}'%7D) / (pg_stat_user_tables_n_live_tup + pg_stat_user_tables_n_dead_tup)) 
      value: '{{ $value }}'
      summary: 'Postgresql too many dead tuples (instance {{ $labels.instance }})'
      description: 'PostgreSQL dead tuples is too large'
  - alert: PostgresqlSplitBrain
    expr: count(pg_replication_is_replica{alerting_required!='false'} == 0) != 1
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: count(pg_replication_is_replica%7Binstance='{{  $labels.instance  }}'%7D)
      value: '{{ $value }}'
      summary: 'Postgresql split brain (instance {{ $labels.instance }})'
      description: 'Split Brain, too many primary Postgresql databases in read-write mode'
  - alert: PostgresqlPromotedNode
    expr: pg_replication_is_replica and changes(pg_replication_is_replica{alerting_required!='false'}[1m]) > 0
    for: 3m
    labels:
      alert_scc: false
      severity: standard
    annotations:
      metric_name: pg_replication_is_replica and changes(pg_replication_is_replica%7Binstance='{{  $labels.instance  }}'%7D%5b1m%5d)
      value: '{{ $value }}'
      summary: 'Postgresql promoted node (instance {{ $labels.instance }})'
      description: 'Postgresql standby server has been promoted as primary node'
  - alert: PostgresqlSslCompressionActive
    expr: sum(pg_stat_ssl_compression{alerting_required!='false'}) > 0
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: sum(pg_stat_ssl_compression%7Binstance='{{  $labels.instance  }}'%7D)
      value: '{{ $value }}'
      summary: 'Postgresql SSL compression active (instance {{ $labels.instance }})'
      description: 'Database connections with SSL compression enabled. This may add significant jitter in replication delay. Replicas should turn off SSL compression via `sslcompression=0` in `recovery.conf`.'
  - alert: PostgresqlTooManyLocksAcquired
    expr: ((sum (pg_locks_count{alerting_required!='false'})) / (pg_settings_max_locks_per_transaction * pg_settings_max_connections)) > 0.20
    for: 3m
    labels:
      alert_scc: false
      severity: critical
    annotations:
      metric_name: ((sum (pg_locks_count%7Binstance='{{  $labels.instance  }}'%7D)) / (pg_settings_max_locks_per_transaction * pg_settings_max_connections))
      value: '{{ $value }}'
      summary: 'Postgresql too many locks acquired (instance {{ $labels.instance }})'
      description: 'Too many locks acquired on the database. If this alert happens frequently, we may need to increase the postgres setting max_locks_per_transaction.'