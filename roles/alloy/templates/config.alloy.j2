// Grafana Alloy configuration
// Generated by Ansible - Do not edit manually
{% macro river_map(values) -%}
{ {% for key, value in values.items() %}{{ key | to_json }} = {{ value | string | to_json }}{% if not loop.last %}, {% endif %}{% endfor %} }
{%- endmacro %}

logging {
  level  = "{{ alloy_log_level }}"
  format = "logfmt"
}

{% set base_labels = alloy_labels | combine({'host': ansible_hostname | default(inventory_hostname)}) %}
{% set log_labels = base_labels | combine(alloy_loki_external_labels) %}
{% set metric_labels = base_labels | combine(alloy_prometheus_external_labels) %}
{% set loki_enabled = alloy_loki_endpoint | length > 0 %}
{% set remote_write_enabled = alloy_prometheus_remote_write_url | length > 0 %}

{% if loki_enabled %}
loki.write "default" {
  endpoint {
    url = "{{ alloy_loki_endpoint }}"
{% if alloy_loki_tenant_id | length > 0 %}
    tenant_id = "{{ alloy_loki_tenant_id }}"
{% endif %}
  }
}
{% endif %}

{% if remote_write_enabled %}
prometheus.remote_write "default" {
  endpoint {
    url = "{{ alloy_prometheus_remote_write_url }}"
{% if alloy_prometheus_remote_write_headers | length > 0 %}
    headers = {{ river_map(alloy_prometheus_remote_write_headers) }}
{% endif %}
  }

  external_labels = {{ river_map(metric_labels) }}
}
{% endif %}

{% if ansible_os_family != 'Windows' and alloy_linux_metrics_enabled and remote_write_enabled %}
prometheus.exporter.unix "local" {
{% if alloy_linux_metrics_collectors_disabled | length > 0 %}
  disable_collectors = {{ alloy_linux_metrics_collectors_disabled | to_json }}
{% endif %}
{% if alloy_linux_metrics_collectors_enabled | length > 0 %}
  enable_collectors = {{ alloy_linux_metrics_collectors_enabled | to_json }}
{% endif %}
}

prometheus.scrape "linux_host" {
  targets    = prometheus.exporter.unix.local.targets
  forward_to = [prometheus.remote_write.default.receiver]
  job_name   = "integrations/linux_host"
}
{% endif %}

{% if ansible_os_family == 'Windows' and alloy_windows_metrics_enabled and remote_write_enabled %}
prometheus.exporter.windows "local" {
  enabled_collectors = {{ alloy_windows_enabled_collectors | to_json }}
}

prometheus.scrape "windows_host" {
  targets    = prometheus.exporter.windows.local.targets
  forward_to = [prometheus.remote_write.default.receiver]
  job_name   = "integrations/windows_host"
}
{% endif %}

{% if ansible_os_family != 'Windows' and alloy_linux_journal_enabled and loki_enabled %}
loki.source.journal "systemd" {
  max_age    = "{{ alloy_linux_journal_max_age }}"
  labels     = {{ river_map(log_labels | combine({'job': 'systemd-journal', 'log_type': 'system'})) }}
  forward_to = [loki.write.default.receiver]
}
{% endif %}

{% if ansible_os_family != 'Windows' and alloy_linux_file_logs_enabled and loki_enabled %}
loki.source.file "linux_files" {
  targets = [
{% for target in alloy_linux_file_log_targets %}
    {{ river_map(log_labels | combine({'__path__': target.path, 'job': target.job, 'log_type': target.log_type})) }},
{% endfor %}
  ]
  forward_to = [loki.write.default.receiver]
}
{% endif %}

{% if ansible_os_family == 'Windows' and alloy_windows_eventlog_enabled and loki_enabled %}
{% for eventlog in alloy_windows_eventlogs %}
loki.source.windowsevent "{{ eventlog.name | lower }}" {
  eventlog_name = "{{ eventlog.name }}"
  bookmark_path = "{{ alloy_windows_bookmark_dir }}/{{ eventlog.name }}.xml"
  labels        = {{ river_map(log_labels | combine({'job': eventlog.job, 'log_type': eventlog.log_type})) }}
  forward_to    = [loki.write.default.receiver]
}

{% endfor %}
{% endif %}

{% if alloy_extra_config | length > 0 %}
// Custom configuration blocks
{{ alloy_extra_config }}
{% endif %}
