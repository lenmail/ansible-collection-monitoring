// Grafana Alloy configuration
// Generated by Ansible - Do not edit manually

{% if alloy_config.logging is defined %}
logging {
{% for key, value in alloy_config.logging.items() %}
{% if value is string %}
  {{ key }} = "{{ value }}"
{% else %}
  {{ key }} = {{ value | lower }}
{% endif %}
{% endfor %}
}
{% endif %}

{% if alloy_config.discovery is defined %}
{% for discovery_type, discovery_config in alloy_config.discovery.items() %}
discovery.{{ discovery_type }} "{{ discovery_type }}" {
{% if discovery_config is mapping %}
{% for key, value in discovery_config.items() %}
{% if key == "relabel" and value is iterable and value is not string %}
{% for relabel_config in value %}
  relabel_configs {
{% for relabel_key, relabel_value in relabel_config.items() %}
{% if relabel_value is string %}
    {{ relabel_key }} = "{{ relabel_value }}"
{% elif relabel_value is iterable and relabel_value is not string %}
    {{ relabel_key }} = {{ relabel_value | to_json }}
{% else %}
    {{ relabel_key }} = {{ relabel_value }}
{% endif %}
{% endfor %}
  }
{% endfor %}
{% else %}
{% if value is string %}
  {{ key }} = "{{ value }}"
{% elif value is iterable and value is not string %}
  {{ key }} = {{ value | to_json }}
{% else %}
  {{ key }} = {{ value | lower }}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
}
{% endfor %}
{% endif %}

{% if alloy_config.loki is defined %}
{% if alloy_config.loki.write is defined %}
{% for idx, write_config in alloy_config.loki.write %}
loki.write "loki_{{ idx }}" {
{% for key, value in write_config.items() %}
{% if value is string %}
  {{ key }} = "{{ value }}"
{% elif value is iterable and value is not string %}
  {{ key }} = {{ value | to_json }}
{% else %}
  {{ key }} = {{ value }}
{% endif %}
{% endfor %}
}
{% endfor %}
{% endif %}

{% if alloy_config.loki.source is defined %}
{% for source_type, source_configs in alloy_config.loki.source.items() %}
{% if source_configs is iterable and source_configs is not string %}
{% for idx, source_config in source_configs %}
loki.source.{{ source_type }} "{{ source_type }}_{{ idx }}" {
{% for key, value in source_config.items() %}
{% if key == "forward_to" and value is iterable and value is not string %}
  forward_to = [{{ value | map('regex_replace', '^loki_(.*)$', 'loki.write.loki_\\1.receiver') | join(', ') }}]
{% elif key == "targets" and value is iterable and value is not string %}
  targets = [
{% for target in value %}
    {
{% for target_key, target_value in target.items() %}
      {{ target_key }} = "{{ target_value }}",
{% endfor %}
    },
{% endfor %}
  ]
{% elif value is string %}
  {{ key }} = "{{ value }}"
{% elif value is iterable and value is not string %}
  {{ key }} = {{ value | to_json }}
{% else %}
  {{ key }} = {{ value }}
{% endif %}
{% endfor %}
}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% endif %}

{% if alloy_config.prometheus is defined %}
{% if alloy_config.prometheus.remote_write is defined %}
{% for idx, remote_write_config in alloy_config.prometheus.remote_write %}
prometheus.remote_write "prometheus_{{ idx }}" {
{% for key, value in remote_write_config.items() %}
{% if value is string %}
  {{ key }} = "{{ value }}"
{% elif value is iterable and value is not string %}
  {{ key }} = {{ value | to_json }}
{% else %}
  {{ key }} = {{ value }}
{% endif %}
{% endfor %}
}
{% endfor %}
{% endif %}

{% if alloy_config.prometheus.scrape is defined %}
{% for scrape_type, scrape_configs in alloy_config.prometheus.scrape.items() %}
{% if scrape_configs is iterable and scrape_configs is not string %}
{% for idx, scrape_config in scrape_configs %}
prometheus.scrape "{{ scrape_type }}_{{ idx }}" {
{% for key, value in scrape_config.items() %}
{% if key == "forward_to" and value is iterable and value is not string %}
  forward_to = [{{ value | map('regex_replace', '^(.*)$', 'prometheus.remote_write.\\1.receiver') | join(', ') }}]
{% elif value is string %}
  {{ key }} = "{{ value }}"
{% elif value is iterable and value is not string %}
  {{ key }} = {{ value | to_json }}
{% else %}
  {{ key }} = {{ value }}
{% endif %}
{% endfor %}
}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% endif %}

{% if alloy_config.local is defined %}
loki.source.file "local_logs" {
{% for key, value in alloy_config.local.items() %}
{% if key == "file_match" %}
  targets = [
    {__path__ = "{{ value }}"},
  ]
{% elif key == "forward_to" and value is iterable and value is not string %}
  forward_to = [{{ value | map('regex_replace', '^(.*)$', 'loki.write.\\1.receiver') | join(', ') }}]
{% elif value is string %}
  {{ key }} = "{{ value }}"
{% elif value is iterable and value is not string %}
  {{ key }} = {{ value | to_json }}
{% else %}
  {{ key }} = {{ value }}
{% endif %}
{% endfor %}

{% if not alloy_config.local.forward_to is defined %}
  forward_to = [loki.write.loki_0.receiver]
{% endif %}
}
{% endif %}

{% if alloy_config.custom is defined %}
// Custom configuration blocks
{% for custom_block in alloy_config.custom %}
{{ custom_block }}
{% endfor %}
{% endif %}
