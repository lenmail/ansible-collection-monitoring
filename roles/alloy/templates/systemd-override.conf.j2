# Systemd service override for Grafana Alloy
# Generated by Ansible - Do not edit manually

[Service]
{% if alloy_service_override.Environment is defined %}
{% for env_var in alloy_service_override.Environment %}
Environment={{ env_var }}
{% endfor %}
{% endif %}

{% if alloy_service_override.ExecStartPre is defined %}
{% for exec_pre in alloy_service_override.ExecStartPre %}
ExecStartPre={{ exec_pre }}
{% endfor %}
{% endif %}

{% if alloy_service_override.ExecStart is defined %}
ExecStart=
ExecStart={{ alloy_service_override.ExecStart }}
{% endif %}

{% if alloy_service_override.User is defined %}
User={{ alloy_service_override.User }}
{% endif %}

{% if alloy_service_override.Group is defined %}
Group={{ alloy_service_override.Group }}
{% endif %}

{% if alloy_service_override.WorkingDirectory is defined %}
WorkingDirectory={{ alloy_service_override.WorkingDirectory }}
{% endif %}

{% if alloy_service_override.Restart is defined %}
Restart={{ alloy_service_override.Restart }}
{% endif %}

{% if alloy_service_override.RestartSec is defined %}
RestartSec={{ alloy_service_override.RestartSec }}
{% endif %}
