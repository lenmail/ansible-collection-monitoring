{{ ansible_managed | comment }}
[Unit]
Description=Prometheus Unbound Exporter
Documentation=https://github.com/ar51an/unbound-exporter
After=network-online.target
StartLimitInterval=0

[Service]
Type=simple
User=root
Group=prometheus
ExecStart=/usr/local/bin/unbound_exporter \
  --web.listen-address 0.0.0.0:9167{% for flag, flag_value in unbound_exporter_config_flags_extra.items() %} \
  --{{ flag }} {{ flag_value }}{% endfor %}

SyslogIdentifier=unbound_exporter
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
